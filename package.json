{
  "name": "a11y-pr-review-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only AI accessibility review agent for GitHub pull requests.",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
