    "eslint-plugin-jsx-a11y": "^6.10.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
