# GitHub Models settings.
# Create a GitHub PAT with the models scope and paste it in your local .env file.
GITHUB_MODELS_TOKEN=

# Pick a model your GitHub account can access from https://github.com/marketplace/models.
# Good first model to try for lightweight tests:
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# GitHub pull request settings. Required only when reviewing a real PR instead of --files.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
PR_NUMBER=123
